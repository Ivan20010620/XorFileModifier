       </item>
       <item>
        <widget class="QPushButton" name="btnCancel">
         <property name="text"><string>Отменить</string></property>
         <property name="enabled"><bool>false</bool></property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="lblInterval">
         <property name="text"><string>Интервал таймера (сек):</string></property>
